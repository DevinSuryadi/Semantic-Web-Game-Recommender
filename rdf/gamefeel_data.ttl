game:hitman-absolution a gf:Game ;
  gf:rawgId "NaN"^^xsd:integer ;
  gf:title "Hitman: Absolution" ;
  gf:slug "hitman-absolution" ;
  gf:releaseDate "2012-11-19"^^xsd:date ;
  gf:rating "3.76"^^xsd:decimal ;
  gf:metacriticScore "79"^^xsd:integer ;
  gf:playtime "7"^^xsd:integer ;
  gf:description "The direct sequel to the Hitman: Blood money, Absolution tells the story of Agent 47, the true intentions of his Agency and how top Agent became a renegade on the run. Unlike previous games in the series, players will get more linear and cinematic experience. The game revolves around objective-based missions, providing various methods of completion. Players can avoid direct confrontation by disguising themselves in other people?s uniforms and use environmental interactions to distract or kill unsuspecting targets. And in case of raising the alarm, players can try to rush the mission with the direct attack, using dozens of available weapons.\nPlayers can use special vision mechanic, called Instinct. It allows seeing through the solid surfaces in order to observe NPC?s, items that can be interacted with and predict the movement of patrolling guards. Absolution provides players with additional challenges and collectibles in order to invite players to explore the maps." ;
  gf:imageUrl "https://media.rawg.io/media/games/d46/d46373f39458670305704ef089387520.jpg"^^xsd:anyURI ;
