game:apex-legends a gf:Game ;
  gf:rawgId "NaN"^^xsd:integer ;
  gf:title "Apex Legends" ;
  gf:slug "apex-legends" ;
  gf:releaseDate "2019-02-04"^^xsd:date ;
  gf:rating "3.63"^^xsd:decimal ;
  gf:metacriticScore "80"^^xsd:integer ;
  gf:playtime "5"^^xsd:integer ;
  gf:description "Conquer with character in Apex Legends, a free-to-play* Battle Royale shooter where legendary characters with powerful abilities team up to battle for fame and fortune on the fringes of the Frontier. Master an ever-growing roster of diverse legends, deep tactical squad play, and bold new innovations that level-up the Battle Royale experience?all within a rugged world where anything goes. Welcome to the next evolution of Battle Royale.\n\nCharacters you can play as: Caustic, Bangalore, Bloodhound, Crypto, Gibraltar, Lifeline, Loba, Mirage, Octane, Pathfinder, Rampart, Revenant." ;
  gf:imageUrl "https://media.rawg.io/media/games/737/737ea5662211d2e0bbd6f5989189e4f1.jpg"^^xsd:anyURI ;
