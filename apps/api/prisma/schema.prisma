generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RawgGame {
  rawgId         Int       @id
  slug           String    @unique
  title          String
  released       DateTime?
  rating         Float?
  metacritic     Int?
  playtime       Int?
  description    String?
  imageUrl       String?
  genresJson     String    @default("[]")
  platformsJson  String    @default("[]")
  developersJson String    @default("[]")
  publishersJson String    @default("[]")
  tagsJson       String    @default("[]")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  semanticMappings SemanticMapping[]

  @@index([title])
  @@index([slug])
}

model SemanticMapping {
  id         Int      @id @default(autoincrement())
  gameRawgId Int
  dimension  String
  value      String
  source     String
  confidence Int      @default(1)
  evidence   String?
  createdAt  DateTime @default(now())

  game RawgGame @relation(fields: [gameRawgId], references: [rawgId], onDelete: Cascade)

  @@unique([gameRawgId, dimension, value])
  @@index([dimension, value])
  @@index([source])
}
